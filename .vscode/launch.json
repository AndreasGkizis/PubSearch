{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch API (ReSharper)",
      "type": "dotnet",
      "request": "launch",
      "preLaunchTask": "build",
      "projectPath": "${workspaceFolder}/API/ResearchPublications.API.csproj",
      "args": [],
      "cwd": "${workspaceFolder}/API",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Launch API (C# Dev Kit)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/API/bin/Debug/net10.0/ResearchPublications.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/API",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
